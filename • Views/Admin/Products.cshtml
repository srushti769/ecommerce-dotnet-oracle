@model List<ECommerceApp.Models.Product>
@{
    ViewBag.Title = "Products";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container-fluid mt-4">
  <div class="d-flex justify-content-between mb-3">
    <h2>Product Management</h2>
    <a href="@Url.Action("AddProduct","Admin")" class="btn btn-primary">+ Add Product</a>
  </div>
  @if(TempData["Success"]!=null){<div class="alert alert-success">@TempData["Success"]</div>}
  <table class="table table-hover table-bordered shadow">
    <thead class="table-dark">
      <tr><th>ID</th><th>Name</th><th>Category</th><th>Price</th><th>Stock</th><th>Status</th><th>Actions</th></tr>
    </thead>
    <tbody>
      @foreach(var p in Model){
        <tr>
          <td>@p.ProductId</td>
          <td>@p.Name</td>
          <td><span class="badge bg-secondary">@p.Category</span></td>
          <td>Rs. @p.Price.ToString("N2")</td>
          <td><span class="badge @(p.Stock>5?"bg-success":"bg-danger")">@p.Stock</span></td>
          <td><span class="badge @(p.IsActive?"bg-success":"bg-secondary")">@(p.IsActive?"Active":"Inactive")</span></td>
          <td>
            <a href="@Url.Action("EditProduct","Admin",new{id=p.ProductId})" class="btn btn-sm btn-warning">Edit</a>
            <a href="@Url.Action("DeleteProduct","Admin",new{id=p.ProductId})" class="btn btn-sm btn-danger"
               onclick="return confirm('Delete this product?')">Delete</a>
          </td>
        </tr>
      }
    </tbody>
  </table>
</div>
