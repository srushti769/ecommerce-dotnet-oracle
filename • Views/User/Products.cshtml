@model List<ECommerceApp.Models.Product>
@{
    ViewBag.Title = "Shop";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container mt-4">
  <h2 class="mb-3">Browse Products</h2>
  @using(Html.BeginForm("Products","User",FormMethod.Get)){
    <div class="row mb-3">
      <div class="col-md-5">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search..." />
      </div>
      <div class="col-md-4">
        <select name="category" class="form-control">
          <option value="">All Categories</option>
          <option value="Electronics">Electronics</option>
          <option value="Footwear">Footwear</option>
          <option value="Bags">Bags</option>
          <option value="Clothing">Clothing</option>
        </select>
      </div>
      <div class="col-md-3">
        <button type="submit" class="btn btn-primary w-100">Search</button>
      </div>
    </div>
  }
  @if(TempData["Success"]!=null){<div class="alert alert-success">@TempData["Success"]</div>}
  @if(TempData["Error"]!=null){<div class="alert alert-danger">@TempData["Error"]</div>}
  <div class="row">
    @foreach(var p in Model){
      <div class="col-md-4 mb-4">
        <div class="card shadow h-100">
          <img src="@(string.IsNullOrEmpty(p.ImageUrl)?"https://via.placeholder.com/300x200?text=Product":p.ImageUrl)"
               class="card-img-top" style="height:160px;object-fit:cover"/>
          <div class="card-body">
            <h5>@p.Name</h5>
            <p class="text-muted small">@p.Description</p>
            <span class="badge bg-secondary">@p.Category</span>
            <div class="d-flex justify-content-between align-items-center mt-2">
              <strong class="text-primary">Rs. @p.Price.ToString("N2")</strong>
              <small class="text-muted">Stock: @p.Stock</small>
            </div>
          </div>
          <div class="card-footer">
            @if(p.Stock>0){
              <button class="btn btn-primary w-100" data-toggle="modal" data-target="#m@(p.ProductId)">Buy Now</button>
              <div class="modal fade" id="m@(p.ProductId)" tabindex="-1">
                <div class="modal-dialog">
                  <div class="modal-content">
                    <div class="modal-header">
                      <h5>Order: @p.Name</h5>
                      <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                    </div>
                    @using(Html.BeginForm("PlaceOrder","User",FormMethod.Post)){
                      <div class="modal-body">
                        <input type="hidden" name="productId" value="@p.ProductId"/>
                        <div class="form-group mb-3">
                          <label>Quantity (Max: @p.Stock)</label>
                          <input type="number" name="quantity" class="form-control" min="1" max="@p.Stock" value="1" required/>
                        </div>
                        <div class="form-group mb-3">
                          <label>Payment Method</label>
                          <select name="paymentMethod" class="form-control">
                            <option value="COD">Cash on Delivery</option>
                            <option value="Online">Online Payment</option>
                            <option value="UPI">UPI</option>
                            <option value="Card">Card</option>
                          </select>
                        </div>
                        <div class="form-group">
                          <label>Delivery Address</label>
                          <textarea name="address" class="form-control" rows="2" required></textarea>
                        </div>
                      </div>
                      <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success">Confirm Order</button>
                      </div>
                    }
                  </div>
                </div>
              </div>
            } else {
              <button class="btn btn-secondary w-100" disabled>Out of Stock</button>
            }
          </div>
        </div>
      </div>
    }
  </div>
</div>
